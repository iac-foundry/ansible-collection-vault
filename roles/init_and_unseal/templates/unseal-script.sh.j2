#!/bin/bash
# /opt/vault/unseal.sh
# Vault auto-unseal script — called by systemd service on restart
# P1-8: Includes retry logic to wait for Vault to be ready
# P1-9: Checks seal status before and after unsealing

set -e

export VAULT_ADDR="{{ vault_api_endpoint }}"
export VAULT_CACERT="{{ vault_cacert_path }}"

UNSEAL_SCRIPT_LOG="/var/log/vault/unseal.log"
UNSEAL_RETRY_ATTEMPTS="{{ vault_unseal_retry_max_attempts }}"
UNSEAL_RETRY_WAIT="{{ vault_unseal_retry_wait_seconds }}"

# Ensure log directory exists
mkdir -p /var/log/vault
chown vault:vault /var/log/vault

{
  echo "========== Vault Auto-Unseal Start $(date) =========="

  # Step 1: Wait for Vault to be ready (P1-8 retry logic)
  echo "Waiting for Vault API to be ready (timeout: ${UNSEAL_RETRY_ATTEMPTS} attempts, ${UNSEAL_RETRY_WAIT}s each)..."
  ATTEMPT=0
  while [ $ATTEMPT -lt $UNSEAL_RETRY_ATTEMPTS ]; do
    # No -f here: Vault's /v1/sys/health intentionally returns non-2xx
    # status codes (503 sealed, 429/472/473 standby/DR states, 501 not
    # initialized) for states this script is specifically waiting to act
    # on. curl -f treats any non-2xx as failure, so a sealed-but-healthy
    # Vault (exactly the state we want to unseal) could never be detected
    # as "ready" -- this loop would exhaust all retries against a perfectly
    # responsive Vault. Without -f, curl exits 0 as long as it received any
    # HTTP response at all; only a real connection failure is non-zero.
    if curl -s --cacert "$VAULT_CACERT" "$VAULT_ADDR/v1/sys/health" > /dev/null 2>&1; then
      echo "✓ Vault API is ready"
      break
    fi
    ATTEMPT=$((ATTEMPT + 1))
    echo "  Attempt $ATTEMPT/$UNSEAL_RETRY_ATTEMPTS: Vault not ready, waiting ${UNSEAL_RETRY_WAIT}s..."
    sleep "$UNSEAL_RETRY_WAIT"
  done

  if [ $ATTEMPT -ge $UNSEAL_RETRY_ATTEMPTS ]; then
    echo "✗ Vault API did not become ready after ${UNSEAL_RETRY_ATTEMPTS} attempts. Exiting."
    echo "Troubleshoot: Check Vault container logs (docker logs vault)"
    exit 1
  fi

  # Step 2: Read unseal keys from secure file
  echo "Reading unseal keys from {{ vault_unseal_keys_path }}..."
  if [ ! -f "{{ vault_unseal_keys_path }}" ]; then
    echo "✗ Unseal keys not found at {{ vault_unseal_keys_path }}. Exiting."
    exit 1
  fi

  KEYS=($(jq -r '.keys[]' {{ vault_unseal_keys_path }}))
  {# Bash's array-length syntax for KEYS, written verbatim, opens with the
     same two punctuation characters Jinja2 uses to open a comment block,
     which previously made Jinja2 scan ahead for a matching close and fail
     with a template syntax error. Building it as a plain string literal
     inside an output expression sidesteps that; the count is then reused
     as a normal shell variable for the rest of this function. #}
  KEY_COUNT={{ '${#KEYS[@]}' }}
  if [ "$KEY_COUNT" -lt {{ vault_unseal_key_threshold }} ]; then
    echo "✗ Not enough unseal keys (found $KEY_COUNT, need {{ vault_unseal_key_threshold }}). Exiting."
    exit 1
  fi

  # Step 3: Check if already unsealed (idempotency)
  SEAL_STATUS=$(vault status -format=json 2>/dev/null | jq -r '.sealed // "unknown"' || echo "error")
  if [ "$SEAL_STATUS" = "false" ]; then
    echo "✓ Vault is already unsealed. Nothing to do."
    echo "========== Vault Auto-Unseal Complete (already unsealed) $(date) =========="
    exit 0
  fi

  # Step 4: Unseal Vault with first {{ vault_unseal_key_threshold }} keys
  echo "Unsealing Vault with {{ vault_unseal_key_threshold }}-of-{{ vault_unseal_key_shares }} keys..."
  for i in $(seq 0 $(({{ vault_unseal_key_threshold }} - 1))); do
    echo "  Submitting key $((i+1))/{{ vault_unseal_key_threshold }}..."
    vault operator unseal "${KEYS[$i]}" > /dev/null 2>&1
    if [ $? -ne 0 ]; then
      echo "  ⚠ Warning: Unseal key $((i+1)) failed (may already be applied)"
    else
      echo "  ✓ Key $((i+1)) applied"
    fi
  done

  # Step 5: Verify unseal status
  echo "Verifying Vault seal status..."
  sleep 1  # Wait for Vault to process unseal commands
  FINAL_STATUS=$(vault status -format=json 2>/dev/null | jq -r '.sealed // "unknown"' || echo "error")

  if [ "$FINAL_STATUS" = "false" ]; then
    echo "✓ Vault successfully unsealed"
    echo "========== Vault Auto-Unseal Complete (success) $(date) =========="
    exit 0
  else
    echo "✗ Vault is still sealed after unsealing. Status: $FINAL_STATUS"
    echo "Troubleshoot: Check Vault logs, verify unseal keys are correct"
    echo "========== Vault Auto-Unseal Complete (FAILURE) $(date) =========="
    exit 1
  fi

} >> "$UNSEAL_SCRIPT_LOG" 2>&1
