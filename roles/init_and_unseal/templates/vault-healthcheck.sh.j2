#!/bin/bash
# /usr/local/bin/vault-healthcheck.sh
# Periodic seal status check (P1-9 mitigation)
# Called by systemd timer every 60s; alerts if Vault is sealed

export VAULT_ADDR="{{ vault_api_endpoint }}"
export VAULT_CACERT="{{ vault_cacert_path }}"

HEALTHCHECK_LOG="/var/log/vault/healthcheck.log"

# Ensure log directory exists
mkdir -p /var/log/vault
chown vault:vault /var/log/vault

{
  TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

  # Query Vault health endpoint. No -f: Vault intentionally returns
  # non-2xx (503 sealed, 429/472/473 standby/DR, 501 not initialized) for
  # states this check needs to distinguish via the JSON body itself --
  # curl -f discards the body on any non-2xx, which made SEALED always
  # resolve to "unknown" while sealed, the one state this check exists to
  # detect and act on (it never reached the auto-unseal trigger below).
  HEALTH=$(curl -s --cacert "$VAULT_CACERT" "$VAULT_ADDR/v1/sys/health" 2>/dev/null || echo "{}")
  # NOT '.sealed // "unknown"': jq's // treats false the same as
  # null/missing, so every time Vault was genuinely healthy and unsealed
  # (sealed: false) this discarded that value and reported "unknown"
  # instead -- a false "cannot determine seal status" alert on the one
  # state that needed no action at all. Sealed:true was never affected
  # (true is not falsy to //), so the auto-unseal trigger branch below was
  # never broken by this -- only the healthy-case logging was wrong.
  SEALED=$(echo "$HEALTH" | jq -r 'if .sealed == null then "unknown" else .sealed end' 2>/dev/null || echo "error")

  if [ "$SEALED" = "error" ] || [ "$SEALED" = "unknown" ]; then
    echo "[$TIMESTAMP] ⚠ WARNING: Cannot determine Vault seal status (API unreachable?)"
    systemctl status vault
    echo "[$TIMESTAMP] Consider restarting Vault: systemctl restart vault"
  elif [ "$SEALED" = "true" ]; then
    echo "[$TIMESTAMP] ✗ ALERT: Vault is SEALED (unexpected)"
    echo "[$TIMESTAMP] Attempting to start auto-unseal service..."
    systemctl start vault-auto-unseal.service
    echo "[$TIMESTAMP] Auto-unseal service started; check logs at /var/log/vault/unseal.log"
  else
    echo "[$TIMESTAMP] ✓ Vault is unsealed (healthy)"
  fi

} >> "$HEALTHCHECK_LOG" 2>&1
